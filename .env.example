# 本文件是 .env 的示例模板，可以复制一份并改名为 .env。
# .env 里填写真实密钥；.env.example 不要填写真实密钥，也不要上传真实密钥。
#
# PowerShell 复制命令：
# Copy-Item .env.example .env

# DeepSeek：用于生成剧本、分镜、提示词、审核意见等文本内容。
DEEPSEEK_API_KEY=

# 火山引擎 Ark：用于 Seedream 生图、Seedance 生视频。
ARK_API_KEY=

# 兼容旧代码的 Ark 密钥别名；通常可以和 ARK_API_KEY 填同一个值。
VOLCENGINE_API_KEY=
